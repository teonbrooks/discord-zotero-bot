# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Zotero API Token
# Get from: https://www.zotero.org/settings/keys
ZOTERO_TOKEN=your_zotero_api_token_here

# Zotero Group ID
# Find in your group library URL: zotero.org/groups/{GROUP_ID}/
ZOTERO_GROUP_ID=your_group_id_here

# Category name to monitor (default: papers)
PAPERS_CATEGORY_NAME=papers

# Maximum messages to scan per channel for /scan_papers command (default: 100)
MAX_MESSAGES_PER_CHANNEL=100
